{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/data/(.*)",
      "dest": "/public/data/$1"
    },
    {
      "src": "/health",
      "dest": "/public/health"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
